# Trading Journal env template (no real secrets)

TELEGRAM_JOURAL=replace_with_telegram_bot_token
TELEGRAM_JOURNAL_CHAT=replace_with_chat_id

WEBAPP_URL=http://localhost:5000
WEBAPP_PORT=5000
PINE_WEBHOOK_SECRET=replace_with_random_webhook_secret

FINNHUB_API_KEY=replace_with_key
NEWSAPI_KEY=replace_with_key
TRADING_ECONOMICS_KEY=replace_with_key
EODHD_API_KEY=replace_with_key

ORACLE_VM_IP=replace_with_oracle_vm_ip
GITHUB_JOURNAL_REPO=https://github.com/brusnyak/trading-journal.git

# cTrader Open API - Get these from: https://openapi.ctrader.com/apps (Playground)
CTRADER_CLIENT_ID=your_client_id_here
CTRADER_CLIENT_SECRET=your_client_secret_here
CTRADER_ACCESS_TOKEN=your_access_token_here
CTRADER_REFRESH_TOKEN=your_refresh_token_here
# CTRADER_ACCOUNT_ID=optional_if_you_have_multiple_accounts
# CTRADER_HOST_TYPE=demo  # demo or live
