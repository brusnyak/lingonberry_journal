# Trading Journal Configuration

# ============================================
# TELEGRAM BOT (Required)
# ============================================
# Get bot token from @BotFather on Telegram
TELEGRAM_JOURAL=your_bot_token_here
# Your Telegram user ID or chat ID (for authorization)
TELEGRAM_JOURNAL_CHAT=your_chat_id_here

# ============================================
# WEBAPP CONFIGURATION
# ============================================
# Local development: http://localhost:5000/mini
# Production: https://your-domain.com/mini (update after deployment)
WEBAPP_URL=http://localhost:5000/mini
WEBAPP_PORT=5000

# Webhook secret for TradingView Pine Script alerts (optional)
PINE_WEBHOOK_SECRET=your_random_secret_here

# ============================================
# AI / LLM (Hermes Agent + Trading Analysis)
# ============================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free

# Hermes Agent Telegram integration
HERMES_TELEGRAM_TOKEN=your_hermes_telegram_bot_token
HERMES_TELEGRAM_CHAT_ID=your_telegram_chat_id

# ============================================
# TRADING — TradeLocker (Paper Trading + Live)
# ============================================
TL_ACTIVE_ENV=demo                                 # "demo" or "live" — which env to use
TL_ENVIRONMENT_DEMO=https://demo.tradelocker.com     # or .tradelockerlive.com for live
TL_USERNAME_DEMO=your_tradelocker_email
TL_PASSWORD_DEMO=your_tradelocker_password
TL_SERVER_DEMO=GFTTL

# Live credentials (uncomment when ready)
# TL_ENVIRONMENT_LIVE=https://live.tradelockerlive.com
# TL_USERNAME_LIVE=your_live_email
# TL_PASSWORD_LIVE=your_live_password
# TL_SERVER_LIVE=GFTTL

# Account numbers from TradeLocker UI
TL_ACC_NUM_25K=2165806                              # 25K GFT demo (master)
TL_ACC_NUM_100K=2165807                             # 100K GFT demo (slave)

# TradeLocker Copy Trader
TL_ACC_NUM_MASTER=2165806
TL_ACC_NUM_SLAVE=2165807
# TL_MASTER_ACCOUNT and TL_SLAVE_ACCOUNT also accepted

# TradeLocker Position Manager
TL_MASTER_ACCOUNT=2165806                           # which account to manage

# ============================================
# TRADING — cTrader Open API (Demo)
# ============================================
# Register redirect URL: https://recareo.uk/callback
# Use demo account credentials only until execution gate passes.
CTRADER_CLIENT_ID=your_ctrader_openapi_client_id
CTRADER_SECRET=your_ctrader_openapi_secret
CTRADER_ACCESS_TOKEN=your_ctrader_access_token
CTRADER_REFRESH_TOKEN=your_ctrader_refresh_token
CTRADER_ACCOUNT_ID=your_ctid_trader_account_id
CTRADER_ACCOUNT_NUMBER=your_visible_account_number
# dead env var — not used in code
CTRADER_DEMO_EXECUTION_ENABLED=false

# cTrader Mirror (25K master → 100K slave)
CTRADER_ACC_NUM_MASTER=44798689
CTRADER_ACC_NUM_SLAVE=47747211
COPY_RISK_PCT=0.005
COPY_POLL_INTERVAL=3
COPY_LOT_STEP=0.01
COPY_MAX_LOTS=20.0
COPY_DRY_RUN=true
COPY_HEARTBEAT=20

# Trend Strategy (cTrader master account)
TREND_DRY_RUN=true
TREND_STRATEGY=ema_cross        # sma_cross | ema_cross | price_vs_ma
TREND_SYMBOL=BTCUSD
TREND_MA_FAST=20
TREND_MA_SLOW=50
TREND_TIMEFRAME=2               # 1=M1 2=M5 3=M15 4=M30 5=H1
TREND_POSITION_SIZE=0.001
TREND_SL_ATR=2.0                # SL = entry ± ATR * this
TREND_TP_RR=1.5                 # TP = entry ± SL_dist * this
TREND_POLL_INTERVAL=15
TREND_COOLDOWN_BARS=3
TREND_OHLC_CACHE=30
TREND_HEARTBEAT=20

# Position Manager
PM_ACCOUNT_IDS=44798689,47747211
PM_DRY_RUN=true
PM_POLL_INTERVAL=5
PM_BE_MULTIPLE=1.0
PM_TRAIL_MULTIPLE=1.5
PM_TIGHTEN_MULTIPLE=2.0
PM_SPREAD_BUFFER=0.3
PM_SWING_PERIOD=2
PM_SWING_LENGTH=3
PM_SWING_BUFFER=0.1
PM_OHLC_COUNT=100
PM_OHLC_CACHE_SEC=30
PM_HEARTBEAT=60
PM_NEWS_PARTIAL_PCT=0.5

# ============================================
# TRADING — Binance (Optional)
# ============================================
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET_API_KEY=your_binance_testnet_key
BINANCE_TESTNET_API_SECRET=your_binance_testnet_secret

# ============================================
# TRADING — Bybit (Optional)
# ============================================
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET_API_KEY=your_bybit_testnet_key
BYBIT_TESTNET_API_SECRET=your_bybit_testnet_secret

# ============================================
# TRADING — BingX (crypto engine, webapp/crypto_execute.py)
# ============================================
BINGX_API_KEY=your_bingx_api_key
BINGX_API_SECRET=your_bingx_api_secret
# true (default) = BingX's VST sandbox (open-api-vst.*) -- same key works
# for both, no separate demo key needed. Must be explicitly set to "false"
# to place real orders on live trading.
BINGX_SANDBOX=true

# ============================================
# DEPLOYMENT
# ============================================
ORACLE_VM_IP=replace_with_oracle_vm_ip
ORACLE_VM_USER=ubuntu
ORACLE_VM_KEY=your_ssh_key
GITHUB_JOURNAL_REPO=https://github.com/brusnyak/trading-journal.git
