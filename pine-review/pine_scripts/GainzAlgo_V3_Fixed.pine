//@version=6
indicator("GainzAlgo V3.1 - Supertrend + Min 2R", 
     overlay=true, 
     max_lines_count=500, 
     max_labels_count=500,
     max_boxes_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// V3.1 - Supertrend filter + strict min 2R:R + selective logic
// ══════════════════════════════════════════════════════════════════════════════
// KEY CHANGES:
// 1. Added Supertrend filter for trend confirmation
// 2. Enforced minimum 2:1 Risk:Reward ratio
// 3. Optional recent Supertrend flip requirement for selectivity
// 4. Higher quality signals with better win rate potential
// ══════════════════════════════════════════════════════════════════════════════

// ==================== INPUTS ====================
// Core Settings
htfBias = input.timeframe("240", "HTF Bias Timeframe", group="Core")
swingLength = input.int(5, "Swing Length", minval=1, group="Core")
breakType = input.string("Body", "Break Type", options=["Body", "Wick"], group="Core")
coolDown = input.int(10, "Signal Cooldown", minval=1, group="Core")

// Filters
useVWAP = input.bool(true, "Use VWAP Filter", group="Filters")
useHTF = input.bool(false, "Use HTF Bias Filter", group="Filters")
requireSweep = input.bool(true, "Require Liquidity Sweep", group="Filters")
volStrength = input.bool(false, "Volume Confirmation", group="Filters")
volThreshold = input.float(1.2, "Volume Threshold", minval=1.0, group="Filters")

// Supertrend
showST = input.bool(true, "Show Supertrend", group="Supertrend")
stLength = input.int(7, "Supertrend ATR Length", minval=1, group="Supertrend")
stMult = input.float(2.0, "Supertrend Multiplier", step=0.1, group="Supertrend")
requireSTFlip = input.bool(false, "Require Recent ST Flip (more selective)", group="Supertrend")

// AMD / Session
showAMD = input.bool(true, "Show Asian Range", group="Sessions")
asianSession = input.string("2000-0000", "Asian Session (UTC)", group="Sessions")

// Visual
showStructure = input.bool(true, "Show Structure Labels", group="Visual")
showOB = input.bool(true, "Show Order Blocks", group="Visual")
showLiquidity = input.bool(true, "Show Liquidity Levels", group="Visual")
showVWAPLine = input.bool(true, "Show VWAP Line", group="Visual")
showStats = input.bool(true, "Show Stats Table", group="Visual")
showTPSLLines = input.bool(true, "Show TP/SL Lines", group="Visual")

// ==================== COLORS & CONSTANTS ====================
color_bull = #2e7d32
color_bear = #c62828
color_liq_high = #2e7d32
color_liq_low = #f06292
color_ob_bull = color.new(#2e7d32, 80)
color_ob_bear = color.new(#c62828, 80)
color_amd = color.new(color.gray, 92)

// ==================== DATA STRUCTURES ====================
// Liquidity
var array<line> liqLines = array.new<line>()
var array<label> liqLabels = array.new<label>()
var array<float> liqPrices = array.new<float>()
var array<bool> liqIsHigh = array.new<bool>()
var array<bool> liqSwept = array.new<bool>()

// Order Blocks - ENHANCED TRACKING
var array<box> obBoxes = array.new<box>()
var array<line> obMids = array.new<line>()
var array<float> obTops = array.new<float>()
var array<float> obBottoms = array.new<float>()
var array<bool> obIsBullish = array.new<bool>()
var array<int> obBars = array.new<int>()  // Track when OB was created

// State
var float lastHigh = na
var float lastLow = na
var int lastHighIdx = na
var int lastLowIdx = na
var string trend = "neutral"
var int lastSignalBar = 0

// Win Rate Tracking
var array<float> signal_entry = array.new<float>()
var array<float> signal_sl = array.new<float>()
var array<float> signal_tp = array.new<float>()
var array<bool> signal_isLong = array.new<bool>()
var array<int> signal_bar = array.new<int>()
var array<bool> signal_closed = array.new<bool>()
var array<bool> signal_won = array.new<bool>()
var int totalWins = 0
var int totalLosses = 0
var int totalSignals = 0

// ==================== VWAP CALCULATION ====================
var float vwapSum = 0.0
var float volumeSum = 0.0

newSession = ta.change(time("D")) != 0
if newSession
    vwapSum := 0.0
    volumeSum := 0.0

typicalPrice = (high + low + close) / 3
vwapSum += typicalPrice * volume
volumeSum += volume
vwap = volumeSum > 0 ? vwapSum / volumeSum : close

vwapBullish = close > vwap
vwapBearish = close < vwap

plot(showVWAPLine ? vwap : na, "VWAP", color=color.new(color.yellow, 0), linewidth=2)

atr14 = ta.atr(14)

// ==================== SUPERTREND ====================
[st, stDir] = ta.supertrend(stMult, stLength)
stBullish = stDir < 0
stBearish = stDir > 0

plot(showST ? st : na, "Supertrend", color=stBullish ? #00ff88 : #ff0088, linewidth=2)

// Track recent Supertrend flip (within 8 bars)
var int lastFlipBar = na
if ta.change(stDir) != 0
    lastFlipBar := bar_index

stRecentFlip = not na(lastFlipBar) and bar_index - lastFlipBar <= 8

// ==================== HTF BIAS ====================
htf_ema20 = request.security(syminfo.tickerid, htfBias, ta.ema(close, 20), lookahead=barmerge.lookahead_off)
htf_ema50 = request.security(syminfo.tickerid, htfBias, ta.ema(close, 50), lookahead=barmerge.lookahead_off)
htf_close = request.security(syminfo.tickerid, htfBias, close, lookahead=barmerge.lookahead_off)

htfBullish = htf_close > htf_ema20 and htf_ema20 > htf_ema50
htfBearish = htf_close < htf_ema20 and htf_ema20 < htf_ema50

// ==================== VOLUME ANALYSIS ====================
avgVol = ta.sma(volume, 20)
isHighVol = volume > (avgVol * volThreshold)

// ==================== ASIAN RANGE (AMD) ====================
isInSession(sess) => not na(time(timeframe.period, sess, "UTC"))
isAsian = isInSession(asianSession)

var float asianHigh = na
var float asianLow = na
var box asianBox = na
var bool sweptAsianLow = false
var bool sweptAsianHigh = false

if isAsian and not isAsian[1]
    asianHigh := high
    asianLow := low
    sweptAsianLow := false
    sweptAsianHigh := false
    if showAMD
        asianBox := box.new(bar_index, asianHigh, bar_index, asianLow, 
                           bgcolor=color_amd, border_color=color.new(color.gray, 50))
else if isAsian
    asianHigh := math.max(high, asianHigh)
    asianLow := math.min(low, asianLow)
    if showAMD
        box.set_top(asianBox, asianHigh)
        box.set_bottom(asianBox, asianLow)
        box.set_right(asianBox, bar_index)

// Detect Asian range sweep
if not isAsian and not na(asianLow)
    if low < asianLow
        sweptAsianLow := true
    if high > asianHigh
        sweptAsianHigh := true

// ==================== SWING DETECTION ====================
float hh = ta.highest(high, swingLength * 2 + 1)
float ll = ta.lowest(low, swingLength * 2 + 1)
bool isSwingHigh = high[swingLength] == hh
bool isSwingLow = low[swingLength] == ll

float check_high = breakType == "Body" ? math.max(open, close) : high
float check_low = breakType == "Body" ? math.min(open, close) : low

var bool currentSweptLow = false
var bool currentSweptHigh = false

// Handle swing highs
if isSwingHigh
    float currentHigh = high[swingLength]
    int currentBar = bar_index - swingLength
    string labelTxt = na(lastHigh) or currentHigh > lastHigh ? "HH" : "LH"
    
    if showStructure
        label.new(currentBar, currentHigh, labelTxt, 
                 style=label.style_label_down, 
                 color=labelTxt == "HH" ? color_bull : color_bear, 
                 textcolor=color.white, size=size.small)
    
    if showLiquidity
        line l = line.new(currentBar, currentHigh, bar_index, currentHigh, 
                         color=color_liq_high, width=1)
        label lb = label.new(currentBar, currentHigh, "liq", 
                            style=label.style_none, textcolor=color_liq_high, size=size.tiny)
        array.push(liqLines, l)
        array.push(liqLabels, lb)
        array.push(liqPrices, currentHigh)
        array.push(liqIsHigh, true)
        array.push(liqSwept, false)
    
    lastHigh := currentHigh
    lastHighIdx := currentBar

// Handle swing lows
if isSwingLow
    float currentLow = low[swingLength]
    int currentBar = bar_index - swingLength
    string labelTxt = na(lastLow) or currentLow < lastLow ? "LL" : "HL"
    
    if showStructure
        label.new(currentBar, currentLow, labelTxt, 
                 style=label.style_label_up, 
                 color=labelTxt == "LL" ? color_bear : color_bull, 
                 textcolor=color.white, size=size.small)
    
    if showLiquidity
        line l = line.new(currentBar, currentLow, bar_index, currentLow, 
                         color=color_liq_low, width=1)
        label lb = label.new(currentBar, currentLow, "liq", 
                            style=label.style_none, textcolor=color_liq_low, size=size.tiny)
        array.push(liqLines, l)
        array.push(liqLabels, lb)
        array.push(liqPrices, currentLow)
        array.push(liqIsHigh, false)
        array.push(liqSwept, false)
    
    lastLow := currentLow
    lastLowIdx := currentBar

// ==================== BOS / CHoCH / ORDER BLOCK CREATION ====================
// NEW: Store when BOS happens to create OB
var bool newBullishBOS = false
var bool newBearishBOS = false

newBullishBOS := false
newBearishBOS := false

// Break of high (bullish)
if not na(lastHigh) and check_high > lastHigh
    string pattern = trend == "bearish" ? "CHoCH" : "BOS"
    
    line.new(lastHighIdx, lastHigh, bar_index, lastHigh, 
            color=color_bull, width=1)
    label.new(bar_index, lastHigh, pattern + " ↑", 
             style=label.style_label_left, 
             color=color.new(color_bull, 30), 
             textcolor=color.white, size=size.small)
    
    // Create bullish Order Block
    if showOB and (not volStrength or isHighVol)
        int obBar = na
        // Find last BEARISH candle before the break
        for i = 1 to math.min(50, bar_index - lastHighIdx)
            if close[i] < open[i]
                obBar := bar_index - i
                break
        
        if not na(obBar)
            float t = high[bar_index - obBar]
            float b = low[bar_index - obBar]
            float m = (t + b) / 2
            
            box bx = box.new(obBar, t, bar_index, b, 
                            bgcolor=color_ob_bull, 
                            border_color=color.new(color_bull, 60))
            line ln = line.new(obBar, m, bar_index, m, 
                              color=color.new(color_bull, 40), 
                              style=line.style_dotted)
            
            array.push(obBoxes, bx)
            array.push(obMids, ln)
            array.push(obTops, t)
            array.push(obBottoms, b)
            array.push(obIsBullish, true)
            array.push(obBars, bar_index)
            
            newBullishBOS := true
    
    trend := "bullish"
    lastHigh := na

// Break of low (bearish)
if not na(lastLow) and check_low < lastLow
    string pattern = trend == "bullish" ? "CHoCH" : "BOS"
    
    line.new(lastLowIdx, lastLow, bar_index, lastLow, 
            color=color_bear, width=1)
    label.new(bar_index, lastLow, pattern + " ↓", 
             style=label.style_label_left, 
             color=color.new(color_bear, 30), 
             textcolor=color.white, size=size.small)
    
    // Create bearish Order Block
    if showOB and (not volStrength or isHighVol)
        int obBar = na
        // Find last BULLISH candle before the break
        for i = 1 to math.min(50, bar_index - lastLowIdx)
            if close[i] > open[i]
                obBar := bar_index - i
                break
        
        if not na(obBar)
            float t = high[bar_index - obBar]
            float b = low[bar_index - obBar]
            float m = (t + b) / 2
            
            box bx = box.new(obBar, t, bar_index, b, 
                            bgcolor=color_ob_bear, 
                            border_color=color.new(color_bear, 60))
            line ln = line.new(obBar, m, bar_index, m, 
                              color=color.new(color_bear, 40), 
                              style=line.style_dotted)
            
            array.push(obBoxes, bx)
            array.push(obMids, ln)
            array.push(obTops, t)
            array.push(obBottoms, b)
            array.push(obIsBullish, false)
            array.push(obBars, bar_index)
            
            newBearishBOS := true
    
    trend := "bearish"
    lastLow := na

// ==================== UPDATE & MANAGE ARRAYS ====================
// Update Order Blocks
if array.size(obBoxes) > 0
    for i = array.size(obBoxes) - 1 to 0
        box.set_right(array.get(obBoxes, i), bar_index)
        line.set_x2(array.get(obMids, i), bar_index)
        
        // Check mitigation
        bool isBull = array.get(obIsBullish, i)
        float obTop = array.get(obTops, i)
        float obBot = array.get(obBottoms, i)
        
        bool mitigated = isBull ? (close < obBot) : (close > obTop)
        
        if mitigated
            box.delete(array.get(obBoxes, i))
            line.delete(array.get(obMids, i))
            array.remove(obBoxes, i)
            array.remove(obMids, i)
            array.remove(obTops, i)
            array.remove(obBottoms, i)
            array.remove(obIsBullish, i)
            array.remove(obBars, i)

// Update Liquidity Lines
currentSweptLow := false
currentSweptHigh := false

if array.size(liqLines) > 0
    for i = array.size(liqLines) - 1 to 0
        line l = array.get(liqLines, i)
        float p = array.get(liqPrices, i)
        bool isH = array.get(liqIsHigh, i)
        bool swept = array.get(liqSwept, i)
        
        line.set_x2(l, bar_index)
        
        if not swept
            if isH and high > p
                line.set_style(l, line.style_dashed)
                array.set(liqSwept, i, true)
                currentSweptHigh := true
            
            if not isH and low < p
                line.set_style(l, line.style_dashed)
                array.set(liqSwept, i, true)
                currentSweptLow := true
        
        // Cleanup old levels
        if (isH and close > p + atr14) or (not isH and close < p - atr14)
            line.delete(l)
            label.delete(array.get(liqLabels, i))
            array.remove(liqLines, i)
            array.remove(liqLabels, i)
            array.remove(liqPrices, i)
            array.remove(liqIsHigh, i)
            array.remove(liqSwept, i)

// Track recent sweeps with expiry
var bool recentSweepLow = false
var int sweepLowExpiry = 0
if currentSweptLow or sweptAsianLow
    recentSweepLow := true
    sweepLowExpiry := bar_index + 12
if bar_index > sweepLowExpiry
    recentSweepLow := false
    sweptAsianLow := false

var bool recentSweepHigh = false
var int sweepHighExpiry = 0
if currentSweptHigh or sweptAsianHigh
    recentSweepHigh := true
    sweepHighExpiry := bar_index + 12
if bar_index > sweepHighExpiry
    recentSweepHigh := false
    sweptAsianHigh := false

// ==================== FIND NEAREST TP TARGETS ====================
findNearestTP_Long(float entry) =>
    float bestTP = na
    if array.size(liqPrices) > 0
        for j = 0 to array.size(liqPrices) - 1
            if array.get(liqIsHigh, j) and not array.get(liqSwept, j)
                float price = array.get(liqPrices, j)
                if price > entry and (na(bestTP) or price < bestTP)
                    bestTP := price
    bestTP

findNearestTP_Short(float entry) =>
    float bestTP = na
    if array.size(liqPrices) > 0
        for j = 0 to array.size(liqPrices) - 1
            if not array.get(liqIsHigh, j) and not array.get(liqSwept, j)
                float price = array.get(liqPrices, j)
                if price < entry and (na(bestTP) or price > bestTP)
                    bestTP := price
    bestTP

// ==================== FIND OB FOR SL ====================
findNearestOB_Long() =>
    float sl = na
    if array.size(obBoxes) > 0
        for i = array.size(obBoxes) - 1 to 0
            if array.get(obIsBullish, i)
                sl := array.get(obBottoms, i)
                break
    sl

findNearestOB_Short() =>
    float sl = na
    if array.size(obBoxes) > 0
        for i = array.size(obBoxes) - 1 to 0
            if not array.get(obIsBullish, i)
                sl := array.get(obTops, i)
                break
    sl

// ==================== SIGNAL LOGIC - V3.1 ====================
var bool isLongSignal = false
var bool isShortSignal = false

isLongSignal := false
isShortSignal := false

// Check cooldown
bool cooldownOK = bar_index - lastSignalBar > coolDown

// LONG SIGNAL: Price touches bullish OB after BOS with sweep + Supertrend + min 2R
if cooldownOK and trend == "bullish" and array.size(obBoxes) > 0
    // Check filters first
    bool vwapOK = not useVWAP or vwapBullish
    bool htfOK = not useHTF or htfBullish
    bool sweepOK = not requireSweep or recentSweepLow
    bool stOK = stBullish and (not requireSTFlip or stRecentFlip)
    
    if vwapOK and htfOK and sweepOK and stOK
        // Find most recent bullish OB
        for i = array.size(obBoxes) - 1 to 0
            if array.get(obIsBullish, i)
                float obTop = array.get(obTops, i)
                float obBot = array.get(obBottoms, i)
                int obCreated = array.get(obBars, i)
                
                // Price must touch OB (wick into zone)
                bool touching = low <= obTop and high >= obBot
                
                // OB must be recent (within last 50 bars)
                bool isRecent = bar_index - obCreated <= 50
                
                if touching and isRecent
                    float entry = close
                    float sl = findNearestOB_Long()
                    
                    if na(sl) or sl >= entry
                        sl := low - atr14 * 0.8
                    
                    float tp = findNearestTP_Long(entry)
                    
                    // Skip if no valid TP or TP too close
                    if na(tp) or tp <= entry
                        continue
                    
                    // Calculate R:R and enforce minimum 2:1
                    float risk = entry - sl
                    float reward = tp - entry
                    float rr = reward / risk
                    
                    if rr >= 2.0
                        isLongSignal := true
                        break

// SHORT SIGNAL: Price touches bearish OB after BOS with sweep + Supertrend + min 2R
if cooldownOK and trend == "bearish" and array.size(obBoxes) > 0
    // Check filters first
    bool vwapOK = not useVWAP or vwapBearish
    bool htfOK = not useHTF or htfBearish
    bool sweepOK = not requireSweep or recentSweepHigh
    bool stOK = stBearish and (not requireSTFlip or stRecentFlip)
    
    if vwapOK and htfOK and sweepOK and stOK
        // Find most recent bearish OB
        for i = array.size(obBoxes) - 1 to 0
            if not array.get(obIsBullish, i)
                float obTop = array.get(obTops, i)
                float obBot = array.get(obBottoms, i)
                int obCreated = array.get(obBars, i)
                
                // Price must touch OB (wick into zone)
                bool touching = high >= obBot and low <= obTop
                
                // OB must be recent (within last 50 bars)
                bool isRecent = bar_index - obCreated <= 50
                
                if touching and isRecent
                    float entry = close
                    float sl = findNearestOB_Short()
                    
                    if na(sl) or sl <= entry
                        sl := high + atr14 * 0.8
                    
                    float tp = findNearestTP_Short(entry)
                    
                    // Skip if no valid TP or TP too close
                    if na(tp) or tp >= entry
                        continue
                    
                    // Calculate R:R and enforce minimum 2:1
                    float risk = sl - entry
                    float reward = entry - tp
                    float rr = reward / risk
                    
                    if rr >= 2.0
                        isShortSignal := true
                        break

// ==================== UPDATE WIN RATE TRACKING ====================
if array.size(signal_entry) > 0
    for i = array.size(signal_entry) - 1 to 0
        if not array.get(signal_closed, i)
            bool isLong = array.get(signal_isLong, i)
            float entryPrice = array.get(signal_entry, i)
            float slPrice = array.get(signal_sl, i)
            float tpPrice = array.get(signal_tp, i)
            
            // Check if SL hit
            if isLong and low <= slPrice
                array.set(signal_closed, i, true)
                array.set(signal_won, i, false)
                totalLosses += 1
            else if not isLong and high >= slPrice
                array.set(signal_closed, i, true)
                array.set(signal_won, i, false)
                totalLosses += 1
            
            // Check if TP hit
            else if isLong and high >= tpPrice
                array.set(signal_closed, i, true)
                array.set(signal_won, i, true)
                totalWins += 1
            else if not isLong and low <= tpPrice
                array.set(signal_closed, i, true)
                array.set(signal_won, i, true)
                totalWins += 1

winRate = (totalWins + totalLosses) > 0 ? (totalWins / (totalWins + totalLosses)) * 100 : 0.0

// ==================== PLOT SIGNALS ====================
if isLongSignal
    float entry = close
    float sl = findNearestOB_Long()
    
    if na(sl) or sl >= entry
        sl := low - atr14 * 0.8
    
    float tp = findNearestTP_Long(entry)
    
    if na(tp) or tp <= entry
        tp := entry + (entry - sl) * 2.0
    
    float rr = (tp - entry) / (entry - sl)
    
    // Store signal
    array.push(signal_entry, entry)
    array.push(signal_sl, sl)
    array.push(signal_tp, tp)
    array.push(signal_isLong, true)
    array.push(signal_bar, bar_index)
    array.push(signal_closed, false)
    array.push(signal_won, false)
    totalSignals += 1
    
    if array.size(signal_entry) > 50
        array.shift(signal_entry)
        array.shift(signal_sl)
        array.shift(signal_tp)
        array.shift(signal_isLong)
        array.shift(signal_bar)
        array.shift(signal_closed)
        array.shift(signal_won)
    
    // Draw zones
    box.new(bar_index, entry, bar_index + 15, sl, 
           bgcolor=color.new(color_bear, 85), 
           border_color=color.new(color_bear, 50), 
           border_width=1)
    
    box.new(bar_index, tp, bar_index + 15, entry, 
           bgcolor=color.new(color_bull, 85), 
           border_color=color.new(color_bull, 50), 
           border_width=1)
    
    if showTPSLLines
        line.new(bar_index, tp, bar_index + 30, tp, 
                color=color.new(color.lime, 40), 
                style=line.style_solid, width=2)
        line.new(bar_index, sl, bar_index + 30, sl, 
                color=color.new(color.red, 40), 
                style=line.style_solid, width=2)
        
        label.new(bar_index + 30, tp, str.tostring(tp, format.mintick), 
                 style=label.style_label_left, 
                 color=color.new(color.lime, 70), 
                 textcolor=color.lime, size=size.tiny)
        label.new(bar_index + 30, sl, str.tostring(sl, format.mintick), 
                 style=label.style_label_left, 
                 color=color.new(color.red, 70), 
                 textcolor=color.red, size=size.tiny)
    
    label.new(bar_index, low, 
             str.format("🔵 BUY\nR:R {0,number,#.#}", rr), 
             style=label.style_label_up, 
             color=color_bull, 
             textcolor=color.white, 
             size=size.large,
             yloc=yloc.belowbar)
    
    lastSignalBar := bar_index

if isShortSignal
    float entry = close
    float sl = findNearestOB_Short()
    
    if na(sl) or sl <= entry
        sl := high + atr14 * 0.8
    
    float tp = findNearestTP_Short(entry)
    
    if na(tp) or tp >= entry
        tp := entry - (sl - entry) * 2.0
    
    float rr = (entry - tp) / (sl - entry)
    
    // Store signal
    array.push(signal_entry, entry)
    array.push(signal_sl, sl)
    array.push(signal_tp, tp)
    array.push(signal_isLong, false)
    array.push(signal_bar, bar_index)
    array.push(signal_closed, false)
    array.push(signal_won, false)
    totalSignals += 1
    
    if array.size(signal_entry) > 50
        array.shift(signal_entry)
        array.shift(signal_sl)
        array.shift(signal_tp)
        array.shift(signal_isLong)
        array.shift(signal_bar)
        array.shift(signal_closed)
        array.shift(signal_won)
    
    // Draw zones
    box.new(bar_index, sl, bar_index + 15, entry, 
           bgcolor=color.new(color_bear, 85), 
           border_color=color.new(color_bear, 50), 
           border_width=1)
    
    box.new(bar_index, entry, bar_index + 15, tp, 
           bgcolor=color.new(color_bull, 85), 
           border_color=color.new(color_bull, 50), 
           border_width=1)
    
    if showTPSLLines
        line.new(bar_index, tp, bar_index + 30, tp, 
                color=color.new(color.lime, 40), 
                style=line.style_solid, width=2)
        line.new(bar_index, sl, bar_index + 30, sl, 
                color=color.new(color.red, 40), 
                style=line.style_solid, width=2)
        
        label.new(bar_index + 30, tp, str.tostring(tp, format.mintick), 
                 style=label.style_label_left, 
                 color=color.new(color.lime, 70), 
                 textcolor=color.lime, size=size.tiny)
        label.new(bar_index + 30, sl, str.tostring(sl, format.mintick), 
                 style=label.style_label_left, 
                 color=color.new(color.red, 70), 
                 textcolor=color.red, size=size.tiny)
    
    label.new(bar_index, high, 
             str.format("🔴 SELL\nR:R {0,number,#.#}", rr), 
             style=label.style_label_down, 
             color=color_bear, 
             textcolor=color.white, 
             size=size.large,
             yloc=yloc.abovebar)
    
    lastSignalBar := bar_index

// ==================== ALERTS ====================
alertcondition(isLongSignal, title="GainzAlgo V3 BUY", message="BUY Signal @ {{close}}")
alertcondition(isShortSignal, title="GainzAlgo V3 SELL", message="SELL Signal @ {{close}}")

// ==================== STATS TABLE ====================
if showStats and barstate.islast
    var table t = table.new(position.top_right, 2, 11, 
                           bgcolor=color.new(color.black, 10), 
                           frame_color=color.gray, 
                           frame_width=1, 
                           border_width=1)
    
    // Header
    table.cell(t, 0, 0, "GainzAlgo V3.1", 
              text_color=color.white, 
              bgcolor=color.new(color.blue, 40), 
              text_size=size.normal)
    table.merge_cells(t, 0, 0, 1, 0)
    
    // Supertrend
    stCol = stBullish ? color.green : stBearish ? color.red : color.gray
    stText = stBullish ? "BULL" : stBearish ? "BEAR" : "NEUTRAL"
    table.cell(t, 0, 1, "ST:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, stText, 
              text_color=color.white, 
              bgcolor=color.new(stCol, 60), 
              text_size=size.small)
    
    // HTF Bias
    htfCol = htfBullish ? color.green : htfBearish ? color.red : color.gray
    htfText = htfBullish ? "BULL" : htfBearish ? "BEAR" : "NEUTRAL"
    table.cell(t, 0, 2, "HTF:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, htfText, 
              text_color=color.white, 
              bgcolor=color.new(htfCol, 60), 
              text_size=size.small)
    
    // VWAP
    vwapCol = vwapBullish ? color.green : vwapBearish ? color.red : color.gray
    vwapText = vwapBullish ? "BULL" : vwapBearish ? "BEAR" : "NEUTRAL"
    table.cell(t, 0, 3, "VWAP:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, vwapText, 
              text_color=color.white, 
              bgcolor=color.new(vwapCol, 60), 
              text_size=size.small)
    
    // Trend
    trendCol = trend == "bullish" ? color.green : trend == "bearish" ? color.red : color.gray
    table.cell(t, 0, 4, "Trend:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, trend, 
              text_color=color.white, 
              bgcolor=color.new(trendCol, 60), 
              text_size=size.small)
    
    // Sweep
    sweepText = recentSweepLow ? "LOW ✓" : recentSweepHigh ? "HIGH ✓" : "NONE"
    sweepCol = recentSweepLow or recentSweepHigh ? color.purple : color.gray
    table.cell(t, 0, 5, "Sweep:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, sweepText, 
              text_color=color.white, 
              bgcolor=color.new(sweepCol, 60), 
              text_size=size.small)
    
    // Active OBs
    numOBs = array.size(obBoxes)
    table.cell(t, 0, 6, "OBs:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(numOBs), 
              text_color=color.white, 
              text_size=size.small)
    
    // Liquidity Levels
    numLiq = array.size(liqPrices)
    table.cell(t, 0, 7, "Liq:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 7, str.tostring(numLiq), 
              text_color=color.white, 
              text_size=size.small)
    
    // Total Signals
    table.cell(t, 0, 8, "Signals:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 8, str.tostring(totalSignals), 
              text_color=color.white, 
              text_size=size.small)
    
    // Open
    openPos = array.size(signal_entry) - (totalWins + totalLosses)
    table.cell(t, 0, 9, "Open:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 9, str.tostring(openPos), 
              text_color=color.white, 
              text_size=size.small)
    
    // Win Rate
    wrCol = winRate >= 60 ? color.rgb(26,138,30) : winRate >= 45 ? color.rgb(176,105,0) : color.red
    wrText = (totalWins + totalLosses) > 0 ? 
             str.format("{0,number,#}% ({1}/{2})", winRate, totalWins, totalWins + totalLosses) : 
             "N/A"
    table.cell(t, 0, 10, "Win Rate:", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 10, wrText, 
              text_color=color.white, 
              bgcolor=color.new(wrCol, 60), 
              text_size=size.small)
