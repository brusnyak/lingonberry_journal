//@version=6
indicator("Market Structure Pro", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ==================== INPUTS ====================
mode = input.string("Analysis", "View Mode", options=["Analysis", "Signals Only"], group="Display")
swingLength = input.int(5, "Swing Length", minval=1, group="Structure")
breakType = input.string("Body", "BOS/CHoCH Break Type", options=["Body", "Wick"], group="Structure")

// Session Inputs (UTC)
asianSession = input.string("2000-0000", "Asian Session (UTC)", group="Sessions")
londonSession = input.string("0700-1100", "London Session (UTC)", group="Sessions")
nyKillzone = input.string("1330-1600", "NY Killzone (UTC)", group="Sessions")
showSessions = input.bool(true, "Show Session Boxes", group="Sessions")

// FVG Settings
fvgMitigation = input.string("Partial", "FVG Mitigation Type", options=["Touch", "Partial", "Full"], group="FVG")
fvgThreshold = input.float(0.382, "Partial Fill Threshold", minval=0.0, maxval=1.0, step=0.05, group="FVG")

// Volume Settings
volStrength = input.bool(true, "Filter OBs by Volume Strength", group="Volume Confluence")
volThreshold = input.float(1.2, "Relative Volume Threshold", minval=1.0, group="Volume Confluence")

// Visibility & Patterns
showStructure = mode == "Analysis" and input.bool(true, "Show HH/HL/LL/LH Labels", group="Structure")
showBOS = mode == "Analysis" or true
showOB = mode == "Analysis" or true
showLiquidity = mode == "Analysis" or input.bool(true, "Liquidity Sweep Check", group="Liquidity")
showFVG = mode == "Analysis" and input.bool(true, "Show Fair Value Gaps", group="FVG")
enablePatterns = input.bool(true, "Enable SMC Pattern Filters", group="Signals")
patternType = input.string("All", "Pattern Filter", options=["All", "Classic Buy/Sell", "NY Reversal"], group="Signals")

// Strategy Inputs
coolDown = input.int(10, "Signal Cooling", minval=1, group="Signals")
newsTime = input.string("1530", "Red News Time (UTC, HHMM)", group="Signals", tooltip="Skip signals during this time")

// Multi-TF
higherTF = input.timeframe("60", "Higher TF for POI (e.g., H1)", group="Confluence")
biasTF = input.timeframe("240", "Bias Timeframe (4H recommended)", group="MTF Bias")
biasStrength = input.float(0.7, "Bias Strength Threshold", minval=0.1, maxval=1.0, step=0.1, group="MTF Bias")
showBiasIndicator = input.bool(true, "Show Bias Indicator", group="MTF Bias")
blockCounterTrend = input.bool(true, "Block Counter-Trend Signals", group="MTF Bias")

// Signal Strength Settings
enableSignalScoring = input.bool(true, "Enable Signal Strength Scoring", group="Signal Quality")
minSignalStrength = input.float(0.6, "Minimum Signal Strength", minval=0.1, maxval=1.0, step=0.1, group="Signal Quality")
showSignalStrength = input.bool(true, "Show Signal Strength Labels", group="Signal Quality")

// Theme Settings
darkTheme = input.bool(true, "Dark Theme", group="Display", tooltip="Toggle for light/dark theme compatibility")

// Premium/Discount Array Settings
showPDArray = input.bool(true, "Show Premium/Discount Array", group="PD Array")
pdArrayTF = input.timeframe("30", "PD Array Timeframe", group="PD Array")
pdArrayLookback = input.int(20, "PD Array Lookback Period", minval=5, maxval=100, group="PD Array")
showPDLevels = input.bool(true, "Show PD Percentage Levels", group="PD Array")
pdArrayTransparency = input.int(85, "PD Array Transparency", minval=50, maxval=95, group="PD Array")

// Order Flow & Market Maker Analysis Settings
enableOrderFlow = input.bool(true, "Enable Order Flow Analysis", group="Order Flow")
showMarketPhases = input.bool(true, "Show Market Maker Phases", group="Order Flow")
accumulationMinBars = input.int(15, "Minimum Accumulation Bars", minval=8, maxval=50, group="Order Flow", tooltip="Minimum bars for accumulation phase")
accumulationMaxRange = input.float(1.2, "Max Accumulation Range (ATR)", minval=0.5, maxval=3.0, step=0.1, group="Order Flow", tooltip="Maximum range for accumulation as ATR multiplier")
manipulationThreshold = input.float(0.6, "Manipulation Threshold (ATR)", minval=0.3, maxval=2.0, step=0.1, group="Order Flow", tooltip="ATR multiplier for false breakout detection")
distributionMinMove = input.float(1.5, "Min Distribution Move (ATR)", minval=0.8, maxval=4.0, step=0.1, group="Order Flow", tooltip="Minimum move size for distribution phase")
phaseTransparency = input.int(85, "Phase Box Transparency", minval=70, maxval=95, group="Order Flow")
showPhaseLabels = input.bool(true, "Show Phase Labels", group="Order Flow")
amdTimeframe = input.string("15", "AMD Detection Timeframe", options=["5", "15", "30", "60"], group="Order Flow", tooltip="Higher timeframes give better AMD signals")

// ==================== VARIABLES & COLORS ====================
color_bull = #2e7d32
color_bear = #c62828
color_liq_high = #2e7d32
color_liq_low = #f06292
color_fvg_bull = color.new(#1E90FF, 85)
color_fvg_bear = color.new(#f06292, 85)
color_ob_bull = color.new(#2e7d32, 80)
color_ob_bear = color.new(#c62828, 80)
color_amd = color.new(color.gray, 92)
color_london = color.new(color.blue, 90)
color_ny = color.new(color.green, 90)

// Order Flow Colors
color_accumulation = color.new(#9C27B0, phaseTransparency)  // Purple for accumulation
color_manipulation = color.new(#FF9800, phaseTransparency)  // Orange for manipulation  
color_distribution = color.new(#F44336, phaseTransparency)  // Red for distribution
color_phase_text = darkTheme ? color.white : color.black

// Data Structures
var array<line> liqLines = array.new<line>()
var array<label> liqLabels = array.new<label>()
var array<float> liqPrices = array.new<float>()
var array<bool> liqIsHigh = array.new<bool>()
var array<bool> liqSwept = array.new<bool>()

var array<box> fvgBoxes = array.new<box>()
var array<line> fvgMids = array.new<line>()
var array<float> fvgTops = array.new<float>()
var array<float> fvgBottoms = array.new<float>()
var array<bool> fvgIsBullish = array.new<bool>()

var array<box> obBoxes = array.new<box>()
var array<line> obMids = array.new<line>()
var array<float> obTops = array.new<float>()
var array<float> obBottoms = array.new<float>()
var array<bool> obIsBullish = array.new<bool>()

// Order Flow Data Structures
var array<box> phaseBoxes = array.new<box>()
var array<label> phaseLabels = array.new<label>()
var array<string> phaseTypes = array.new<string>()
var array<int> phaseStartBars = array.new<int>()
var array<float> phaseHighs = array.new<float>()
var array<float> phaseLows = array.new<float>()

// Market Maker Model State
var string currentPhase = "neutral"
var int phaseStartBar = na
var float phaseHigh = na
var float phaseLow = na
var int phaseDuration = 0
var bool phaseTransition = false
var float phaseRange = na
var float phaseStartPrice = na

// AMD Detection Variables
var float accumulationHigh = na
var float accumulationLow = na
var int accumulationBars = 0
var bool inAccumulation = false
var float lastBreakoutLevel = na
var string lastBreakoutDirection = "none"

// Internal State
var float lastHigh = na
var float lastLow = na
var int lastHighIdx = na
var int lastLowIdx = na
var string trend = "neutral"
var int lastSignalBar = 0

// Session Logic
isInSession(sess) => not na(time(timeframe.period, sess, "UTC"))
isAsian = isInSession(asianSession)
isLondon = isInSession(londonSession)
isNY = isInSession(nyKillzone)

var float asianHigh = na
var float asianLow = na
var box asianBox = na
var bool sweptAsianLow = false
var bool sweptAsianHigh = false

var float londonHigh = na
var float londonLow = na
var box londonBox = na

var float nyHigh = na
var float nyLow = na
var box nyBox = na

// Asian Session
if isAsian and not isAsian[1]
    asianHigh := high
    asianLow := low
    sweptAsianLow := false
    sweptAsianHigh := false
    if showSessions
        asianBox := box.new(bar_index, asianHigh, bar_index, asianLow, bgcolor=color_amd, border_color=color.new(color.gray, 50))
else if isAsian
    asianHigh := math.max(high, asianHigh)
    asianLow := math.min(low, asianLow)
    if showSessions
        box.set_top(asianBox, asianHigh)
        box.set_bottom(asianBox, asianLow)
        box.set_right(asianBox, bar_index)

// London Session
if isLondon and not isLondon[1]
    londonHigh := high
    londonLow := low
    if showSessions
        londonBox := box.new(bar_index, londonHigh, bar_index, londonLow, bgcolor=color_london, border_color=color.new(color.blue, 50))
else if isLondon
    londonHigh := math.max(high, londonHigh)
    londonLow := math.min(low, londonLow)
    if showSessions
        box.set_top(londonBox, londonHigh)
        box.set_bottom(londonBox, londonLow)
        box.set_right(londonBox, bar_index)

// NY Killzone
if isNY and not isNY[1]
    nyHigh := high
    nyLow := low
    if showSessions
        nyBox := box.new(bar_index, nyHigh, bar_index, nyLow, bgcolor=color_ny, border_color=color.new(color.green, 50))
else if isNY
    nyHigh := math.max(high, nyHigh)
    nyLow := math.min(low, nyLow)
    if showSessions
        box.set_top(nyBox, nyHigh)
        box.set_bottom(nyBox, nyLow)
        box.set_right(nyBox, bar_index)

// Sweep Detection
if not isAsian and not na(asianLow)
    if low < asianLow
        sweptAsianLow := true
    if high > asianHigh
        sweptAsianHigh := true

// NYM and DO
string ny_tz = "America/New_York"
series bool newNYDay = ta.change(time("D", "", ny_tz)) != 0
var float nym = na
if newNYDay
    nym := open
if not na(nym) and mode == "Analysis"
    line.new(bar_index[1], nym, bar_index, nym, color=color.yellow, width=1, style=line.style_dashed)

series bool newDay = ta.change(time("D")) != 0
var float do_level = na
if newDay
    do_level := open
if not na(do_level) and mode == "Analysis"
    line.new(bar_index[1], do_level, bar_index, do_level, color=color.orange, width=1, style=line.style_dotted)

// Volume
avgVol = ta.sma(volume, 20)
isHighVol = volume > (avgVol * volThreshold)

// Global Calcs
float hh = ta.highest(high, swingLength * 2 + 1)
float ll = ta.lowest(low, swingLength * 2 + 1)
bool isSwingHigh = high[swingLength] == hh
bool isSwingLow = low[swingLength] == ll
float check_high = breakType == "Body" ? math.max(open, close) : high
float check_low = breakType == "Body" ? math.min(open, close) : low
var bool currentSweptLow = false
var bool currentSweptHigh = false
float atr = ta.atr(14)

// Global TA calculations for order flow (to avoid warnings)
float highest_10 = ta.highest(high, 10)
float lowest_10 = ta.lowest(low, 10)
float highest_5 = ta.highest(high, 5)
float lowest_5 = ta.lowest(low, 5)
float highest_20 = ta.highest(close, 20)
float lowest_20 = ta.lowest(close, 20)
float rsi_14 = ta.rsi(close, 14)
float ema_21 = ta.ema(close, 21)

// Higher TF POI
float h1_hh = request.security(syminfo.tickerid, higherTF, ta.highest(high, swingLength))
float h1_ll = request.security(syminfo.tickerid, higherTF, ta.lowest(low, swingLength))
bool nearH1POI = math.abs(close - h1_hh) < atr * 0.5 or math.abs(close - h1_ll) < atr * 0.5

// ==================== MTF BIAS SYSTEM ====================
// 4H Bias Calculation
float htf_ema_fast = request.security(syminfo.tickerid, biasTF, ta.ema(close, 8))
float htf_ema_mid = request.security(syminfo.tickerid, biasTF, ta.ema(close, 21))
float htf_ema_slow = request.security(syminfo.tickerid, biasTF, ta.ema(close, 50))
float htf_close = request.security(syminfo.tickerid, biasTF, close)
float htf_high = request.security(syminfo.tickerid, biasTF, high)
float htf_low = request.security(syminfo.tickerid, biasTF, low)
float htf_atr = request.security(syminfo.tickerid, biasTF, ta.atr(14))

// Bias Strength Components
bool ema_alignment_bull = htf_ema_fast > htf_ema_mid and htf_ema_mid > htf_ema_slow
bool ema_alignment_bear = htf_ema_fast < htf_ema_mid and htf_ema_mid < htf_ema_slow
bool price_above_emas = htf_close > htf_ema_fast
bool price_below_emas = htf_close < htf_ema_fast

// HTF Structure
string htf_trend = request.security(syminfo.tickerid, biasTF, trend)
float htf_momentum = (htf_close - htf_close[1]) / htf_atr
bool strong_momentum = math.abs(htf_momentum) > 0.2

// Simplified Bias Calculation (more sensitive)
float bias_score = 0.0
bias_score += price_above_emas ? 0.4 : price_below_emas ? 0.4 : 0.0  // Price vs EMA
bias_score += ema_alignment_bull or ema_alignment_bear ? 0.3 : 0.0    // EMA alignment
bias_score += htf_trend == "bullish" or htf_trend == "bearish" ? 0.2 : 0.0  // Structure
bias_score += strong_momentum ? 0.1 : 0.0  // Momentum

// Determine Bias Direction and Strength
string htf_bias = "neutral"
bool strong_bias = bias_score >= biasStrength

if bias_score >= 0.3  // Lower threshold for bias detection
    if price_above_emas and (ema_alignment_bull or htf_trend == "bullish")
        htf_bias := "bullish"
    else if price_below_emas and (ema_alignment_bear or htf_trend == "bearish")
        htf_bias := "bearish"

// ==================== PREMIUM/DISCOUNT ARRAY SYSTEM ====================
// Get higher timeframe swing points for PD Array
float pd_high = request.security(syminfo.tickerid, pdArrayTF, ta.highest(high, pdArrayLookback))
float pd_low = request.security(syminfo.tickerid, pdArrayTF, ta.lowest(low, pdArrayLookback))
float pd_range = pd_high - pd_low
float pd_equilibrium = (pd_high + pd_low) / 2

// Calculate PD Array levels (0-100%)
float pd_100 = pd_high                           // 100% - Premium High
float pd_75 = pd_low + (pd_range * 0.75)        // 75% - Premium Zone
float pd_62 = pd_low + (pd_range * 0.618)       // 61.8% - Golden Ratio
float pd_50 = pd_equilibrium                     // 50% - Equilibrium
float pd_38 = pd_low + (pd_range * 0.382)       // 38.2% - Golden Ratio
float pd_25 = pd_low + (pd_range * 0.25)        // 25% - Discount Zone
float pd_0 = pd_low                              // 0% - Discount Low

// Calculate current price position in PD Array (0-100%)
float pd_position = pd_range > 0 ? ((close - pd_low) / pd_range) * 100 : 50

// Determine current PD zone
string pd_zone = "Equilibrium"
if pd_position >= 75
    pd_zone := "Premium High"
else if pd_position >= 62
    pd_zone := "Premium"
else if pd_position >= 38
    pd_zone := "Equilibrium"
else if pd_position >= 25
    pd_zone := "Discount"
else
    pd_zone := "Discount Low"

// PD Array colors
color premium_color = color.new(#ff6b6b, pdArrayTransparency)
color equilibrium_color = color.new(#ffd93d, pdArrayTransparency)
color discount_color = color.new(#6bcf7f, pdArrayTransparency)

// Draw PD Array levels (cleaner approach)
if showPDArray and not na(pd_high) and not na(pd_low) and pd_range > 0 and barstate.islast
    // Premium Zone (75-100%)
    box.new(bar_index - 100, pd_100, bar_index + 20, pd_75, bgcolor=premium_color, border_color=na, extend=extend.right)
    
    // Equilibrium Zone (38.2-61.8%)
    box.new(bar_index - 100, pd_62, bar_index + 20, pd_38, bgcolor=equilibrium_color, border_color=na, extend=extend.right)
    
    // Discount Zone (0-25%)
    box.new(bar_index - 100, pd_25, bar_index + 20, pd_0, bgcolor=discount_color, border_color=na, extend=extend.right)
    
    if showPDLevels
        // Key level lines
        line.new(bar_index - 100, pd_100, bar_index + 20, pd_100, color=color.new(#ff6b6b, 30), width=1, style=line.style_dashed, extend=extend.right)
        line.new(bar_index - 100, pd_75, bar_index + 20, pd_75, color=color.new(#ff6b6b, 50), width=1, extend=extend.right)
        line.new(bar_index - 100, pd_62, bar_index + 20, pd_62, color=color.new(#ffd93d, 30), width=1, extend=extend.right)
        line.new(bar_index - 100, pd_50, bar_index + 20, pd_50, color=color.new(#ffd93d, 0), width=2, style=line.style_solid, extend=extend.right)
        line.new(bar_index - 100, pd_38, bar_index + 20, pd_38, color=color.new(#ffd93d, 30), width=1, extend=extend.right)
        line.new(bar_index - 100, pd_25, bar_index + 20, pd_25, color=color.new(#6bcf7f, 50), width=1, extend=extend.right)
        line.new(bar_index - 100, pd_0, bar_index + 20, pd_0, color=color.new(#6bcf7f, 30), width=1, style=line.style_dashed, extend=extend.right)
        
        // Level labels (only on last bar)
        label.new(bar_index + 5, pd_100, "100%", style=label.style_none, color=na, textcolor=color.new(#ff6b6b, 0), size=size.small)
        label.new(bar_index + 5, pd_75, "75%", style=label.style_none, color=na, textcolor=color.new(#ff6b6b, 30), size=size.small)
        label.new(bar_index + 5, pd_50, "50%", style=label.style_none, color=na, textcolor=color.new(#ffd93d, 0), size=size.small)
        label.new(bar_index + 5, pd_25, "25%", style=label.style_none, color=na, textcolor=color.new(#6bcf7f, 30), size=size.small)
        label.new(bar_index + 5, pd_0, "0%", style=label.style_none, color=na, textcolor=color.new(#6bcf7f, 0), size=size.small)

// ==================== ORDER FLOW & MARKET MAKER ANALYSIS ====================
if enableOrderFlow
    // Get higher timeframe data for better AMD detection
    float amd_high = request.security(syminfo.tickerid, amdTimeframe, high, lookahead=barmerge.lookahead_off)
    float amd_low = request.security(syminfo.tickerid, amdTimeframe, low, lookahead=barmerge.lookahead_off)
    float amd_close = request.security(syminfo.tickerid, amdTimeframe, close, lookahead=barmerge.lookahead_off)
    float amd_open = request.security(syminfo.tickerid, amdTimeframe, open, lookahead=barmerge.lookahead_off)
    float amd_volume = request.security(syminfo.tickerid, amdTimeframe, volume, lookahead=barmerge.lookahead_off)
    float amd_atr = request.security(syminfo.tickerid, amdTimeframe, ta.atr(14), lookahead=barmerge.lookahead_off)
    
    // Calculate range metrics
    float currentRange = amd_high - amd_low
    float avgRange = ta.sma(currentRange, 20)
    bool isRangeCompression = currentRange < (amd_atr * accumulationMaxRange)
    
    // Volume analysis
    float avgVolume = ta.sma(amd_volume, 20)
    bool isNormalVolume = amd_volume > avgVolume * 0.7 and amd_volume < avgVolume * 1.5
    
    // Price action analysis
    bool isConsolidating = math.abs(amd_close - amd_open) < amd_atr * 0.5
    bool nearKeyLevel = math.abs(amd_close - pd_50) < amd_atr * 0.8 or 
                       (not na(asianHigh) and not na(asianLow) and amd_close > asianLow and amd_close < asianHigh)
    
    // ACCUMULATION PHASE DETECTION (Improved)
    // Look for tight ranging price action with normal volume
    if currentPhase != "accumulation"
        if isRangeCompression and isConsolidating and isNormalVolume
            // Start tracking potential accumulation
            if not inAccumulation
                accumulationHigh := amd_high
                accumulationLow := amd_low
                accumulationBars := 1
                inAccumulation := true
            else
                // Update accumulation range
                accumulationHigh := math.max(accumulationHigh, amd_high)
                accumulationLow := math.min(accumulationLow, amd_low)
                accumulationBars += 1
                
                // Check if we have enough bars for accumulation
                if accumulationBars >= accumulationMinBars
                    float accumRange = accumulationHigh - accumulationLow
                    if accumRange <= amd_atr * accumulationMaxRange
                        // Valid accumulation detected
                        currentPhase := "accumulation"
                        phaseStartBar := bar_index - accumulationBars
                        phaseHigh := accumulationHigh
                        phaseLow := accumulationLow
                        phaseRange := accumRange
                        phaseStartPrice := amd_close
                        phaseDuration := accumulationBars
                        phaseTransition := true
        else
            // Reset accumulation tracking if conditions not met
            inAccumulation := false
            accumulationBars := 0
    
    // MANIPULATION PHASE DETECTION (Improved)
    // Look for breakouts from accumulation that fail quickly
    if currentPhase == "accumulation"
        bool breakoutUp = amd_high > phaseHigh + (amd_atr * 0.2)
        bool breakoutDown = amd_low < phaseLow - (amd_atr * 0.2)
        
        if breakoutUp or breakoutDown
            lastBreakoutLevel := breakoutUp ? phaseHigh : phaseLow
            lastBreakoutDirection := breakoutUp ? "up" : "down"
            
            // Check for quick reversal (manipulation)
            bool quickReversal = false
            if breakoutUp and amd_close < phaseHigh - (amd_atr * manipulationThreshold)
                quickReversal := true
            else if breakoutDown and amd_close > phaseLow + (amd_atr * manipulationThreshold)
                quickReversal := true
            
            if quickReversal
                // Manipulation detected
                currentPhase := "manipulation"
                phaseHigh := math.max(phaseHigh, amd_high)
                phaseLow := math.min(phaseLow, amd_low)
                phaseDuration := bar_index - phaseStartBar
                phaseTransition := true
    
    // DISTRIBUTION PHASE DETECTION (Improved)
    // Look for strong moves away from manipulation levels
    if currentPhase == "manipulation"
        bool strongMoveUp = amd_close > lastBreakoutLevel + (amd_atr * distributionMinMove) and lastBreakoutDirection == "down"
        bool strongMoveDown = amd_close < lastBreakoutLevel - (amd_atr * distributionMinMove) and lastBreakoutDirection == "up"
        
        if strongMoveUp or strongMoveDown
            // Distribution phase detected
            currentPhase := "distribution"
            phaseHigh := math.max(phaseHigh, amd_high)
            phaseLow := math.min(phaseLow, amd_low)
            phaseDuration := bar_index - phaseStartBar
            phaseTransition := true
    
    // PHASE COMPLETION AND RESET
    // Reset to neutral after distribution completes or phases get too long
    if currentPhase == "distribution"
        // Check if distribution is complete (price stabilizing)
        bool distributionComplete = isRangeCompression and phaseDuration > 10
        if distributionComplete or phaseDuration > 100
            currentPhase := "neutral"
            phaseStartBar := na
            phaseHigh := na
            phaseLow := na
            phaseDuration := 0
            phaseTransition := true
            inAccumulation := false
            accumulationBars := 0
    
    // Update phase duration for active phases
    if not na(phaseStartBar) and currentPhase != "neutral"
        phaseDuration := bar_index - phaseStartBar
        phaseHigh := math.max(phaseHigh, amd_high)
        phaseLow := math.min(phaseLow, amd_low)
    
    // DRAW PHASE BOXES AND LABELS
    if phaseTransition and showMarketPhases and currentPhase != "neutral"
        // End previous phase box if exists
        if array.size(phaseBoxes) > 0
            lastBox = array.get(phaseBoxes, array.size(phaseBoxes) - 1)
            if not na(lastBox)
                box.set_right(lastBox, bar_index)
        
        // Create new phase box
        if not na(phaseStartBar) and bar_index - phaseStartBar > 2
            color phaseColor = currentPhase == "accumulation" ? color_accumulation :
                              currentPhase == "manipulation" ? color_manipulation :
                              currentPhase == "distribution" ? color_distribution : color.new(color.gray, 95)
            
            box phaseBox = box.new(phaseStartBar, phaseHigh, bar_index + 10, phaseLow, 
                                 bgcolor=phaseColor, border_color=na, extend=extend.right)
            array.push(phaseBoxes, phaseBox)
            
            if showPhaseLabels
                string phaseText = currentPhase == "accumulation" ? "ACCUMULATION" :
                                  currentPhase == "manipulation" ? "MANIPULATION" :
                                  currentPhase == "distribution" ? "DISTRIBUTION" : ""
                
                label phaseLabel = label.new(math.round((phaseStartBar + bar_index) / 2), phaseHigh + amd_atr * 0.3, 
                                           phaseText, style=label.style_none, 
                                           color=na, textcolor=color_phase_text, size=size.normal)
                array.push(phaseLabels, phaseLabel)
    
    // Clean up old phase boxes (keep last 10)
    if array.size(phaseBoxes) > 10
        box.delete(array.get(phaseBoxes, 0))
        array.remove(phaseBoxes, 0)
    
    if array.size(phaseLabels) > 10
        label.delete(array.get(phaseLabels, 0))
        array.remove(phaseLabels, 0)
    
    // Reset transition flag
    phaseTransition := false

// Bias Indicator Display - moved to after metrics calculation

// ==================== HANDLE SWINGS ====================
if isSwingHigh
    float currentHigh = high[swingLength]
    int currentBar = bar_index - swingLength
    string labelTxt = na(lastHigh) or currentHigh > lastHigh ? "HH" : "LH"
    if showStructure
        label.new(currentBar, currentHigh, labelTxt, style=label.style_label_down, color=labelTxt == "HH" ? color_bull : color_bear, textcolor=color.white, size=size.small)
    if showLiquidity
        line l = line.new(currentBar, currentHigh, bar_index, currentHigh, color=color_liq_high, width=1)
        label lb = label.new(currentBar, currentHigh, "liq", style=label.style_none, textcolor=color_liq_high, size=size.tiny)
        array.push(liqLines, l), array.push(liqLabels, lb), array.push(liqPrices, currentHigh), array.push(liqIsHigh, true), array.push(liqSwept, false)
    lastHigh := currentHigh
    lastHighIdx := currentBar

if isSwingLow
    float currentLow = low[swingLength]
    int currentBar = bar_index - swingLength
    string labelTxt = na(lastLow) or currentLow < lastLow ? "LL" : "HL"
    if showStructure
        label.new(currentBar, currentLow, labelTxt, style=label.style_label_up, color=labelTxt == "LL" ? color_bear : color_bull, textcolor=color.white, size=size.small)
    if showLiquidity
        line l = line.new(currentBar, currentLow, bar_index, currentLow, color=color_liq_low, width=1)
        label lb = label.new(currentBar, currentLow, "liq", style=label.style_none, textcolor=color_liq_low, size=size.tiny)
        array.push(liqLines, l), array.push(liqLabels, lb), array.push(liqPrices, currentLow), array.push(liqIsHigh, false), array.push(liqSwept, false)
    lastLow := currentLow
    lastLowIdx := currentBar

// ==================== BOS / CHOCH / OB LOGIC ====================
if showBOS
    if not na(lastHigh) and check_high > lastHigh
        string pattern = trend == "bearish" ? "CHoCH" : "BOS"
        // Enhanced: Only show if aligned with HTF bias or bias is weak
        bool bias_aligned = not strong_bias or htf_bias == "bullish" or htf_bias == "neutral"
        if mode == "Analysis" and bias_aligned
            line.new(lastHighIdx, lastHigh, bar_index, lastHigh, color=color_bull, width=1)
            label.new(bar_index, lastHigh, pattern + " LONG", style=label.style_label_left, color=color.new(color_bull, 30), textcolor=color.white, size=size.small)
       
        if showOB and (not volStrength or isHighVol) and bias_aligned
            int obBar = na
            for i = 1 to math.min(50, bar_index - lastHighIdx)
                if close[i] < open[i]
                    obBar := bar_index - i
                    break
            if not na(obBar)
                float t = high[bar_index - obBar], b = low[bar_index - obBar], m = (t + b) / 2
                box bx = box.new(obBar, t, bar_index, b, bgcolor=color_ob_bull, border_color=mode == "Analysis" ? color.new(color_bull, 60) : na)
                line ln = line.new(obBar, m, bar_index, m, color=mode == "Analysis" ? color.new(color_bull, 40) : na, style=line.style_dotted)
                array.push(obBoxes, bx), array.push(obMids, ln), array.push(obTops, t), array.push(obBottoms, b), array.push(obIsBullish, true)
        trend := "bullish", lastHigh := na

    if not na(lastLow) and check_low < lastLow
        string pattern = trend == "bullish" ? "CHoCH" : "BOS"
        // Enhanced: Only show if aligned with HTF bias or bias is weak
        bool bias_aligned = not strong_bias or htf_bias == "bearish" or htf_bias == "neutral"
        if mode == "Analysis" and bias_aligned
            line.new(lastLowIdx, lastLow, bar_index, lastLow, color=color_bear, width=1)
            label.new(bar_index, lastLow, pattern + " SHORT", style=label.style_label_left, color=color.new(color_bear, 30), textcolor=color.white, size=size.small)
       
        if showOB and (not volStrength or isHighVol) and bias_aligned
            int obBar = na
            for i = 1 to math.min(50, bar_index - lastLowIdx)
                if close[i] > open[i]
                    obBar := bar_index - i
                    break
            if not na(obBar)
                float t = high[bar_index - obBar], b = low[bar_index - obBar], m = (t + b) / 2
                box bx = box.new(obBar, t, bar_index, b, bgcolor=color_ob_bear, border_color=mode == "Analysis" ? color.new(color_bear, 60) : na)
                line ln = line.new(obBar, m, bar_index, m, color=mode == "Analysis" ? color.new(color_bear, 40) : na, style=line.style_dotted)
                array.push(obBoxes, bx), array.push(obMids, ln), array.push(obTops, t), array.push(obBottoms, b), array.push(obIsBullish, false)
        trend := "bearish", lastLow := na

// ==================== UPDATE ARRAYS ====================
if array.size(obBoxes) > 0
    for i = array.size(obBoxes) - 1 to 0
        box.set_right(array.get(obBoxes, i), bar_index)
        line.set_x2(array.get(obMids, i), bar_index)
        if (array.get(obIsBullish, i) and close < array.get(obBottoms, i)) or (not array.get(obIsBullish, i) and close > array.get(obTops, i))
            box.delete(array.get(obBoxes, i)), line.delete(array.get(obMids, i))
            array.remove(obBoxes, i), array.remove(obMids, i), array.remove(obTops, i), array.remove(obBottoms, i), array.remove(obIsBullish, i)

currentSweptLow := false
currentSweptHigh := false
if array.size(liqLines) > 0
    for i = array.size(liqLines) - 1 to 0
        line l = array.get(liqLines, i)
        float p = array.get(liqPrices, i)
        bool isH = array.get(liqIsHigh, i)
        bool swept = array.get(liqSwept, i)
        line.set_x2(l, bar_index)
        if not swept
            if (isH and high > p)
                line.set_style(l, line.style_dashed), array.set(liqSwept, i, true), currentSweptHigh := true
            if (not isH and low < p)
                line.set_style(l, line.style_dashed), array.set(liqSwept, i, true), currentSweptLow := true
        if (isH and close > p) or (not isH and close < p)
            line.delete(l), label.delete(array.get(liqLabels, i))
            array.remove(liqLines, i), array.remove(liqLabels, i), array.remove(liqPrices, i), array.remove(liqIsHigh, i), array.remove(liqSwept, i)

// Signal Logic
var bool recentSweepLow = false
var int sweepLowExpiry = 0
if currentSweptLow or sweptAsianLow
    recentSweepLow := true
    sweepLowExpiry := bar_index + 12
if bar_index > sweepLowExpiry
    recentSweepLow := false

var bool recentSweepHigh = false
var int sweepHighExpiry = 0
if currentSweptHigh or sweptAsianHigh
    recentSweepHigh := true
    sweepHighExpiry := bar_index + 12
if bar_index > sweepHighExpiry
    recentSweepHigh := false

// Pattern Detection
bool asiaAccum = not na(asianHigh) and not na(asianLow) ? (asianHigh - asianLow) < atr * 1.5 : false
bool londonReversal = (trend == "bearish" and low < asianLow and close > open) or (trend == "bullish" and high > asianHigh and close < open)
bool nyContinuation = (close > open and trend == "bullish") or (close < open and trend == "bearish")
bool nyReversal = not nyContinuation and londonReversal
bool isClassicBuySell = asiaAccum and londonReversal and nyContinuation
bool isNYReversalPattern = londonReversal and nyReversal
bool patternMatch = not enablePatterns or patternType == "All" or (patternType == "Classic Buy/Sell" and isClassicBuySell) or (patternType == "NY Reversal" and isNYReversalPattern)

// ==================== SIGNAL STRENGTH SCORING ====================
// Calculate signal strength based on multiple confluence factors
calculateSignalStrength(bool isLong) =>
    float strength = 0.0
    
    // HTF Bias Alignment (18% weight - slightly reduced for order flow)
    if htf_bias == "bullish" and isLong
        strength += 0.18
    else if htf_bias == "bearish" and not isLong
        strength += 0.18
    else if htf_bias == "neutral"
        strength += 0.07  // Neutral bias gets partial credit
    
    // PD Array Position (22% weight - slightly reduced)
    if isLong and (pd_zone == "Discount" or pd_zone == "Discount Low")
        strength += 0.22  // Long signals preferred in discount
    else if not isLong and (pd_zone == "Premium" or pd_zone == "Premium High")
        strength += 0.22  // Short signals preferred in premium
    else if pd_zone == "Equilibrium"
        strength += 0.09  // Neutral zone gets partial credit
    
    // Order Flow Phase Alignment (15% weight - IMPROVED)
    if enableOrderFlow
        if currentPhase == "accumulation"
            strength += 0.08  // Accumulation is neutral but adds some confidence
        else if currentPhase == "manipulation"
            // Manipulation phase - favor reversal signals after liquidity sweep
            if (isLong and trend == "bearish" and recentSweepLow) or (not isLong and trend == "bullish" and recentSweepHigh)
                strength += 0.15  // Counter-trend signals during manipulation get boost
            else
                strength += 0.05  // Trend-following signals get less
        else if currentPhase == "distribution"
            // Distribution phase - favor trend continuation initially, then reversal
            if phaseDuration < 15
                if (isLong and trend == "bullish") or (not isLong and trend == "bearish")
                    strength += 0.12  // Early distribution favors continuation
            else
                if (isLong and trend == "bearish") or (not isLong and trend == "bullish")
                    strength += 0.15  // Late distribution favors reversal
    
    // Session Timing (13% weight - reduced)
    if isLondon or isNY
        strength += 0.13  // High impact sessions
    else if isAsian
        strength += 0.04  // Lower impact session
    
    // Volume Confluence (12% weight - reduced)
    if isHighVol
        strength += 0.12
    
    // Liquidity Sweep (12% weight - reduced)
    if (isLong and recentSweepLow) or (not isLong and recentSweepHigh)
        strength += 0.12
    
    // HTF POI Proximity (8% weight - reduced)
    if nearH1POI
        strength += 0.08
    
    strength

// Store signal strength for current triggers
var float currentLongStrength = na
var float currentShortStrength = na

// Invalidation
bool compression = (high - low) < atr * 0.5
series bool duringNews = not na(time("1", newsTime + "-" + str.tostring(math.min(str.tonumber(newsTime) + 30, 2359))))
bool counter_trend_block = blockCounterTrend and strong_bias and ((htf_bias == "bullish" and trend == "bearish") or (htf_bias == "bearish" and trend == "bullish"))
bool invalid = compression or not nearH1POI or duringNews or counter_trend_block

// Triggers
var float triggeredLongSL = na
var float triggeredShortSL = na
var bool isLongTrigger = false
var bool isShortTrigger = false

isLongTrigger := false
isShortTrigger := false

if array.size(obBoxes) > 0 and bar_index - lastSignalBar > coolDown and not invalid and patternMatch
    for i = 0 to array.size(obBoxes) - 1
        bool isBullOB = array.get(obIsBullish, i)
        float obTop = array.get(obTops, i)
        float obBot = array.get(obBottoms, i)
        
        // Enhanced: Check HTF bias alignment for signals
        bool long_bias_ok = not blockCounterTrend or not strong_bias or htf_bias == "bullish" or htf_bias == "neutral"
        bool short_bias_ok = not blockCounterTrend or not strong_bias or htf_bias == "bearish" or htf_bias == "neutral"
        
        if isBullOB and trend == "bullish" and low <= obTop and low >= obBot and recentSweepLow and long_bias_ok
            // Calculate signal strength
            float longStrength = calculateSignalStrength(true)
            if not enableSignalScoring or longStrength >= minSignalStrength
                isLongTrigger := true
                triggeredLongSL := obBot
                currentLongStrength := longStrength
                
        if not isBullOB and trend == "bearish" and high >= obBot and high <= obTop and recentSweepHigh and short_bias_ok
            // Calculate signal strength
            float shortStrength = calculateSignalStrength(false)
            if not enableSignalScoring or shortStrength >= minSignalStrength
                isShortTrigger := true
                triggeredShortSL := obTop
                currentShortStrength := shortStrength

bool long_changed = ta.change(isLongTrigger) and isLongTrigger
bool short_changed = ta.change(isShortTrigger) and isShortTrigger

// TP Helpers
findNearestTP_Long(float entry) =>
    float bestTP = na
    if array.size(liqPrices) > 0
        for j = 0 to array.size(liqPrices) - 1
            if array.get(liqIsHigh, j) and not array.get(liqSwept, j)
                float price = array.get(liqPrices, j)
                if price > entry and (na(bestTP) or price < bestTP)
                    bestTP := price
    if array.size(fvgBoxes) > 0
        for k = 0 to array.size(fvgBoxes) - 1
            if array.get(fvgIsBullish, k)
                float top = array.get(fvgTops, k)
                float bot = array.get(fvgBottoms, k)
                float mid50 = bot + (top - bot) * 0.5
                if mid50 > entry and (na(bestTP) or mid50 < bestTP)
                    bestTP := mid50
    bestTP := na(bestTP) ? entry + (entry - triggeredLongSL) * 2 : bestTP // Fallback RR=2
    bestTP

findNearestTP_Short(float entry) =>
    float bestTP = na
    if array.size(liqPrices) > 0
        for j = 0 to array.size(liqPrices) - 1
            if not array.get(liqIsHigh, j) and not array.get(liqSwept, j)
                float price = array.get(liqPrices, j)
                if price < entry and (na(bestTP) or price > bestTP)
                    bestTP := price
    if array.size(fvgBoxes) > 0
        for k = 0 to array.size(fvgBoxes) - 1
            if not array.get(fvgIsBullish, k)
                float top = array.get(fvgTops, k)
                float bot = array.get(fvgBottoms, k)
                float mid50 = top - (top - bot) * 0.5
                if mid50 < entry and (na(bestTP) or mid50 > bestTP)
                    bestTP := mid50
    bestTP := na(bestTP) ? entry - (triggeredShortSL - entry) * 2 : bestTP
    bestTP

// Signals
if mode == "Signals Only"
    if long_changed
        float entry = close
        float sl = triggeredLongSL
        if not na(sl) and entry > sl
            float tp = findNearestTP_Long(entry)
            if not na(tp) and tp > entry
                box.new(bar_index, entry, bar_index + 15, sl, bgcolor=color.new(color_bear, 80), border_color=na)
                box.new(bar_index, tp, bar_index + 15, entry, bgcolor=color.new(color_bull, 80), border_color=na)
                
                // Enhanced: Show signal strength
                string signalText = sweptAsianLow ? "AMD-BUY" : "SWEEP-BUY"
                if showSignalStrength and not na(currentLongStrength)
                    signalText := signalText + " (" + str.tostring(currentLongStrength * 100, "#") + "%)"
                
                // Color based on strength
                color signalColor = currentLongStrength >= 0.8 ? color.new(color_bull, 0) : currentLongStrength >= 0.6 ? color.new(color_bull, 30) : color.new(color_bull, 60)
                label.new(bar_index, sl, signalText, style=label.style_label_up, color=signalColor, textcolor=color.white)
                lastSignalBar := bar_index
                sweptAsianLow := false

    if short_changed
        float entry = close
        float sl = triggeredShortSL
        if not na(sl) and entry < sl
            float tp = findNearestTP_Short(entry)
            if not na(tp) and tp < entry
                box.new(bar_index, sl, bar_index + 15, entry, bgcolor=color.new(color_bear, 80), border_color=na)
                box.new(bar_index, entry, bar_index + 15, tp, bgcolor=color.new(color_bull, 80), border_color=na)
                
                // Enhanced: Show signal strength
                string signalText = sweptAsianHigh ? "AMD-SELL" : "SWEEP-SELL"
                if showSignalStrength and not na(currentShortStrength)
                    signalText := signalText + " (" + str.tostring(currentShortStrength * 100, "#") + "%)"
                
                // Color based on strength
                color signalColor = currentShortStrength >= 0.8 ? color.new(color_bear, 0) : currentShortStrength >= 0.6 ? color.new(color_bear, 30) : color.new(color_bear, 60)
                label.new(bar_index, sl, signalText, style=label.style_label_down, color=signalColor, textcolor=color.white)
                lastSignalBar := bar_index
                sweptAsianHigh := false

// ==================== FVG LOGIC & MITIGATION ====================
if showFVG
    if low[0] > high[2]
        box bx = box.new(bar_index - 2, high[2], bar_index, low[0], bgcolor=color_fvg_bull, border_color=na)
        line ln = line.new(bar_index - 2, (low[0]+high[2])/2, bar_index, (low[0]+high[2])/2, color=color.new(#1E90FF, 50), style=line.style_dotted)
        array.push(fvgBoxes, bx), array.push(fvgMids, ln), array.push(fvgTops, low[0]), array.push(fvgBottoms, high[2]), array.push(fvgIsBullish, true)
       
    if high[0] < low[2]
        box bx = box.new(bar_index - 2, high[0], bar_index, low[2], bgcolor=color_fvg_bear, border_color=na)
        line ln = line.new(bar_index - 2, (high[0]+low[2])/2, bar_index, (high[0]+low[2])/2, color=color.new(#f06292, 50), style=line.style_dotted)
        array.push(fvgBoxes, bx), array.push(fvgMids, ln), array.push(fvgTops, low[2]), array.push(fvgBottoms, high[0]), array.push(fvgIsBullish, false)

if array.size(fvgBoxes) > 0
    for i = array.size(fvgBoxes) - 1 to 0
        box.set_right(array.get(fvgBoxes, i), bar_index)
        line.set_x2(array.get(fvgMids, i), bar_index)
        bool isBull = array.get(fvgIsBullish, i)
        float top = array.get(fvgTops, i)
        float bot = array.get(fvgBottoms, i)
        float gap = top - bot
        bool mitigated = false
        if fvgMitigation == "Touch"
            mitigated := isBull ? (low <= top) : (high >= bot)
        else if fvgMitigation == "Partial"
            float th = isBull ? (top - (gap * fvgThreshold)) : (bot + (gap * fvgThreshold))
            mitigated := isBull ? (low <= th) : (high >= th)
        else
            mitigated := isBull ? (low <= bot) : (high >= top)
        if mitigated
            box.delete(array.get(fvgBoxes, i)), line.delete(array.get(fvgMids, i))
            array.remove(fvgBoxes, i), array.remove(fvgMids, i), array.remove(fvgTops, i), array.remove(fvgBottoms, i), array.remove(fvgIsBullish, i)

// Trade Simulation for Metrics
var array<float> tradeEntries = array.new<float>()
var array<float> tradeSLs = array.new<float>()
var array<float> tradeTPs = array.new<float>()
var array<bool> tradeDirections = array.new<bool>() // true for long
var array<bool> tradeOutcomes = array.new<bool>() // wins
var array<float> tradeRRs = array.new<float>()

// Open trades vars
var float openEntry = na
var float openSL = na
var float openTP = na
var bool openDirection = false

// On signal, "enter" trade
if long_changed and na(openEntry)
    openEntry := close
    openSL := triggeredLongSL
    openTP := findNearestTP_Long(openEntry)
    openDirection := true
if short_changed and na(openEntry)
    openEntry := close
    openSL := triggeredShortSL
    openTP := findNearestTP_Short(openEntry)
    openDirection := false

// Monitor open trade
if not na(openEntry)
    if openDirection // long
        if high >= openTP
            array.push(tradeOutcomes, true)
            array.push(tradeRRs, (openTP - openEntry) / (openEntry - openSL))
            openEntry := na
        else if low <= openSL
            array.push(tradeOutcomes, false)
            array.push(tradeRRs, na)
            openEntry := na
    else // short
        if low <= openTP
            array.push(tradeOutcomes, true)
            array.push(tradeRRs, (openEntry - openTP) / (openSL - openEntry))
            openEntry := na
        else if high >= openSL
            array.push(tradeOutcomes, false)
            array.push(tradeRRs, na)
            openEntry := na

// Metrics
// FIXED SECTION START
float winCount = 0.0
if array.size(tradeOutcomes) > 0
    for i = 0 to array.size(tradeOutcomes) - 1
        if array.get(tradeOutcomes, i)
            winCount += 1.0
float winRate = array.size(tradeOutcomes) > 0 ? (winCount / array.size(tradeOutcomes)) * 100 : na
// FIXED SECTION END

float avgRR = 0.0
int wins = 0
if array.size(tradeRRs) > 0
    for i = 0 to array.size(tradeRRs) - 1
        if array.get(tradeOutcomes, i)
            avgRR += array.get(tradeRRs, i)
            wins += 1
if wins > 0
    avgRR /= wins

string recentOutcome = array.size(tradeOutcomes) > 0 ? (array.last(tradeOutcomes) ? "Win" : "Loss") : "N/A"
float recentRR = array.size(tradeRRs) > 0 ? array.last(tradeRRs) : na

// Bias Indicator Display
if showBiasIndicator and mode == "Signals Only"
    // Theme-aware colors
    color header_bg = darkTheme ? color.new(color.gray, 20) : color.new(color.gray, 80)
    color header_text = darkTheme ? color.white : color.black
    color cell_bg = darkTheme ? color.new(color.gray, 90) : color.new(color.gray, 10)
    color cell_text = darkTheme ? color.white : color.black
    
    // Merge with existing stats table
    var table statsTable = table.new(position.top_right, 2, 12, border_width=1, border_color=color.new(color.gray, 50))
    table.cell(statsTable, 0, 0, "Metric", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, 0, "Value", bgcolor=header_bg, text_color=header_text)
    
    // Bias Information
    table.cell(statsTable, 0, 1, "4H Bias", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, 1, htf_bias, bgcolor=htf_bias == "bullish" ? color.new(color_bull, 20) : htf_bias == "bearish" ? color.new(color_bear, 20) : color.new(color.gray, 60), text_color=color.white)
    table.cell(statsTable, 0, 2, "Bias Strength", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, 2, str.tostring(bias_score, "#.##"), bgcolor=strong_bias ? color.new(color.green, 20) : color.new(color.orange, 20), text_color=color.white)
    table.cell(statsTable, 0, 3, "Filter Active", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, 3, blockCounterTrend ? "ON" : "OFF", bgcolor=blockCounterTrend ? color.new(color.green, 20) : color.new(color.red, 20), text_color=color.white)
    
    // Order Flow Information
    if enableOrderFlow
        table.cell(statsTable, 0, 4, "Market Phase", bgcolor=header_bg, text_color=header_text)
        color phase_color = currentPhase == "accumulation" ? color.new(#9C27B0, 20) : 
                           currentPhase == "manipulation" ? color.new(#FF9800, 20) : 
                           currentPhase == "distribution" ? color.new(#F44336, 20) : color.new(color.gray, 60)
        string phase_display = currentPhase == "accumulation" ? "ACCUM" : 
                              currentPhase == "manipulation" ? "MANIP" : 
                              currentPhase == "distribution" ? "DIST" : "NEUTRAL"
        table.cell(statsTable, 1, 4, phase_display, bgcolor=phase_color, text_color=color.white)
        table.cell(statsTable, 0, 5, "Phase Duration", bgcolor=header_bg, text_color=header_text)
        table.cell(statsTable, 1, 5, str.tostring(phaseDuration), bgcolor=cell_bg, text_color=cell_text)
    
    // PD Array Information  
    int pd_row = enableOrderFlow ? 6 : 4
    table.cell(statsTable, 0, pd_row, "PD Zone", bgcolor=header_bg, text_color=header_text)
    color pd_zone_color = pd_zone == "Premium High" or pd_zone == "Premium" ? color.new(#ff6b6b, 20) : pd_zone == "Discount" or pd_zone == "Discount Low" ? color.new(#6bcf7f, 20) : color.new(#ffd93d, 20)
    table.cell(statsTable, 1, pd_row, pd_zone, bgcolor=pd_zone_color, text_color=color.white)
    table.cell(statsTable, 0, pd_row + 1, "PD Position", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, pd_row + 1, str.tostring(pd_position, "#") + "%", bgcolor=cell_bg, text_color=cell_text)
    
    // Performance Metrics
    int perf_row = enableOrderFlow ? 8 : 6
    table.cell(statsTable, 0, perf_row, "Win Rate %", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, perf_row, str.tostring(winRate, "#.#"), bgcolor=cell_bg, text_color=cell_text)
    table.cell(statsTable, 0, perf_row + 1, "Avg RR", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, perf_row + 1, str.tostring(avgRR, "#.##"), bgcolor=cell_bg, text_color=cell_text)
    table.cell(statsTable, 0, perf_row + 2, "Recent Outcome", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, perf_row + 2, recentOutcome, bgcolor=cell_bg, text_color=cell_text)
    table.cell(statsTable, 0, perf_row + 3, "Recent RR", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, perf_row + 3, str.tostring(recentRR, "#.##"), bgcolor=cell_bg, text_color=cell_text)
else if showBiasIndicator and mode == "Analysis"
    // Theme-aware colors for Analysis mode
    color header_bg = darkTheme ? color.new(color.gray, 20) : color.new(color.gray, 80)
    color header_text = darkTheme ? color.white : color.black
    
    // Standalone bias table for Analysis mode
    int table_rows = enableOrderFlow ? 5 : 3
    var table biasTable = table.new(position.bottom_right, 2, table_rows, border_width=1, border_color=color.new(color.gray, 50))
    table.cell(biasTable, 0, 0, "4H Bias", bgcolor=header_bg, text_color=header_text)
    table.cell(biasTable, 1, 0, htf_bias, bgcolor=htf_bias == "bullish" ? color.new(color_bull, 20) : htf_bias == "bearish" ? color.new(color_bear, 20) : color.new(color.gray, 60), text_color=color.white)
    table.cell(biasTable, 0, 1, "Strength", bgcolor=header_bg, text_color=header_text)
    table.cell(biasTable, 1, 1, str.tostring(bias_score, "#.##"), bgcolor=strong_bias ? color.new(color.green, 20) : color.new(color.orange, 20), text_color=color.white)
    table.cell(biasTable, 0, 2, "Filter", bgcolor=header_bg, text_color=header_text)
    table.cell(biasTable, 1, 2, blockCounterTrend ? "ON" : "OFF", bgcolor=blockCounterTrend ? color.new(color.green, 20) : color.new(color.red, 20), text_color=color.white)
    
    // Add order flow information if enabled
    if enableOrderFlow
        table.cell(biasTable, 0, 3, "Phase", bgcolor=header_bg, text_color=header_text)
        color phase_color = currentPhase == "accumulation" ? color.new(#9C27B0, 20) : 
                           currentPhase == "manipulation" ? color.new(#FF9800, 20) : 
                           currentPhase == "distribution" ? color.new(#F44336, 20) : color.new(color.gray, 60)
        string phase_display = currentPhase == "accumulation" ? "ACCUM" : 
                              currentPhase == "manipulation" ? "MANIP" : 
                              currentPhase == "distribution" ? "DIST" : "NEUTRAL"
        table.cell(biasTable, 1, 3, phase_display, bgcolor=phase_color, text_color=color.white)
        table.cell(biasTable, 0, 4, "Duration", bgcolor=header_bg, text_color=header_text)
        table.cell(biasTable, 1, 4, str.tostring(phaseDuration), bgcolor=color.new(color.gray, 60), text_color=color.white)

// Table in Signals Only (now handled above with bias info)
if mode == "Signals Only" and not showBiasIndicator
    // Theme-aware colors
    color header_bg = darkTheme ? color.new(color.gray, 20) : color.new(color.gray, 80)
    color header_text = darkTheme ? color.white : color.black
    color cell_bg = darkTheme ? color.new(color.gray, 90) : color.new(color.gray, 10)
    color cell_text = darkTheme ? color.white : color.black
    
    var table statsTable = table.new(position.top_right, 2, 5, border_width=1, border_color=color.new(color.gray, 50))
    table.cell(statsTable, 0, 0, "Metric", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, 0, "Value", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 0, 1, "Win Rate %", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, 1, str.tostring(winRate, "#.#"), bgcolor=cell_bg, text_color=cell_text)
    table.cell(statsTable, 0, 2, "Avg RR", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, 2, str.tostring(avgRR, "#.##"), bgcolor=cell_bg, text_color=cell_text)
    table.cell(statsTable, 0, 3, "Recent Outcome", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, 3, recentOutcome, bgcolor=cell_bg, text_color=cell_text)
    table.cell(statsTable, 0, 4, "Recent RR", bgcolor=header_bg, text_color=header_text)
    table.cell(statsTable, 1, 4, str.tostring(recentRR, "#.##"), bgcolor=cell_bg, text_color=cell_text)
    table.cell(statsTable, 0, 1, "Win Rate %", bgcolor=color.new(color.gray, 80), text_color=color.new(color.white, 0))
    table.cell(statsTable, 1, 1, str.tostring(winRate, "#.#"), bgcolor=color.new(color.gray, 90), text_color=color.new(color.white, 0))
    table.cell(statsTable, 0, 2, "Avg RR", bgcolor=color.new(color.gray, 80), text_color=color.new(color.white, 0))
    table.cell(statsTable, 1, 2, str.tostring(avgRR, "#.##"), bgcolor=color.new(color.gray, 90), text_color=color.new(color.white, 0))
    table.cell(statsTable, 0, 3, "Recent Outcome", bgcolor=color.new(color.gray, 80), text_color=color.new(color.white, 0))
    table.cell(statsTable, 1, 3, recentOutcome, bgcolor=color.new(color.gray, 90), text_color=color.new(color.white, 0))
    table.cell(statsTable, 0, 4, "Recent RR", bgcolor=color.new(color.gray, 80), text_color=color.new(color.white, 0))
    table.cell(statsTable, 1, 4, str.tostring(recentRR, "#.##"), bgcolor=color.new(color.gray, 90), text_color=color.new(color.white, 0))