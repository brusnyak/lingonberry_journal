[Unit]
Description=Lingonberry Journal Web App
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@APP_USER@
Group=@APP_USER@
WorkingDirectory=@APP_DIR@
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-@APP_DIR@/.env
ExecStart=@APP_DIR@/.venv/bin/python3 webapp/app.py
Restart=on-failure
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
